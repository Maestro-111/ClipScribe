# Repo-wide ignores only. Language/tool-specific patterns live in the relevant
# subproject so their broad directory names (lib/, build/, dist/, target/) can't
# leak across projects:
#   - backend/.gitignore   (Python + ML pipeline)
#   - frontend/.gitignore  (Node / Vite)

# OS
*.DS_Store

# Editors / IDEs
.idea/
.vscode/

# Secrets / local env (matches at any depth: root, backend/, frontend/)
.env
*.env.local

# Test coverage data. An exact filename (no leak risk like lib//build/), and it
# lands at whatever CWD coverage runs from — including the repo root. Backend
# runs from backend/ still hit backend/.gitignore's copy.
.coverage
.coverage.*